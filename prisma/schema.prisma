// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Model
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  phone         String?
  image         String?
  password      String?   // Hashed password
  role          Role      @default(USER)
  ktp_number    String?   // Nomor KTP
  ktp_photo     String?   // URL foto KTP
  
  // Relations
  accounts      Account[]
  sessions      Session[]
  bookings      Booking[]
  reviews       Review[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

// NextAuth Account Model
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// NextAuth Session Model
model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// NextAuth VerificationToken Model
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Room Model
model Room {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  type        RoomType
  price       Decimal  @db.Decimal(12, 2)
  size        String   // e.g., "3x4 meter"
  floor       Int
  available   Int      @default(0) // Jumlah kamar tersedia
  description String   @db.Text
  facilities  Json     // Array of strings
  images      Json     // Array of image URLs
  videoUrl    String?
  isActive    Boolean  @default(true)
  
  // Relations
  bookings    Booking[]
  reviews     Review[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("rooms")
}

// Booking Model
model Booking {
  id             String        @id @default(uuid())
  roomId         String
  userId         String
  startDate      DateTime
  durationMonths Int           // Durasi sewa dalam bulan
  totalAmount    Decimal       @db.Decimal(12, 2)
  status         BookingStatus @default(PENDING)
  notes          String?       @db.Text
  adminNotes     String?       @db.Text // Catatan dari admin
  
  // Relations
  room           Room          @relation(fields: [roomId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
  payment        Payment?
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("bookings")
}

// Payment Model
model Payment {
  id               String        @id @default(uuid())
  bookingId        String        @unique
  amount           Decimal       @db.Decimal(12, 2)
  paymentMethod    PaymentMethod
  paymentProvider  String        // "midtrans", "manual", etc
  transactionId    String?       // ID dari payment gateway
  qrCode           String?       // QR code URL (QRIS)
  vaNumber         String?       // Virtual Account number
  status           PaymentStatus @default(PENDING)
  paidAt           DateTime?
  expiresAt        DateTime?
  metadata         Json?         // Extra data dari payment gateway
  
  // Relations
  booking          Booking       @relation(fields: [bookingId], references: [id])
  
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@map("payments")
}

// Review Model
model Review {
  id        String       @id @default(uuid())
  roomId    String
  userId    String
  bookingId String?      // Optional: link to booking
  rating    Int          // 1-5
  comment   String       @db.Text
  photos    Json?        // Array of photo URLs
  status    ReviewStatus @default(PENDING)
  
  // Relations
  room      Room         @relation(fields: [roomId], references: [id])
  user      User         @relation(fields: [userId], references: [id])
  
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("reviews")
}

// Notification Model
model Notification {
  id        String           @id @default(uuid())
  userId    String?          // Null jika untuk admin
  type      NotificationType
  title     String
  message   String           @db.Text
  data      Json?            // Extra data (booking ID, etc)
  isRead    Boolean          @default(false)
  
  createdAt DateTime         @default(now())

  @@map("notifications")
}

// Settings Model (untuk konfigurasi website)
model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value Json
  
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// Enums
enum Role {
  USER
  ADMIN
}

enum RoomType {
  STANDARD
  DELUXE
  PREMIUM
  STUDIO
}

enum BookingStatus {
  PENDING       // Baru submit, belum di-approve
  APPROVED      // Sudah di-approve admin, belum bayar
  PAID          // Sudah bayar
  REJECTED      // Ditolak admin
  CANCELLED     // Dibatalkan user
  COMPLETED     // Masa sewa selesai
}

enum PaymentMethod {
  QRIS
  BANK_TRANSFER
  EWALLET
  CASH
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  BOOKING_CREATED
  BOOKING_APPROVED
  BOOKING_REJECTED
  PAYMENT_SUCCESS
  PAYMENT_REMINDER
  CONTRACT_EXPIRING
  SYSTEM
}
